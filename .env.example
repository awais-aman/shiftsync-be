# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins for the frontend
CORS_ORIGIN=http://localhost:3000

# Supabase — values from supabase.com/dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used by the JWT guard to verify tokens issued by Supabase Auth.
# Find it under: Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Postgres connection string from Supabase (Project Settings → Database → Connection string → URI)
# Use the pooled connection (port 6543) for the app, and the direct one (5432) for migrations later.
DATABASE_URL=
DIRECT_URL=
